<?xml version="1.0" encoding="utf-8"?>
<!-- Feed local de los .nupkg empaquetados (artifacts/nupkg) para el pack-smoke (CHARTER-07/T057). -->
<configuration>
  <packageSources>
    <clear />
    <add key="weft-local" value="../../artifacts/nupkg" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
